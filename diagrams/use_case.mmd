flowchart TB
    %% ===== Actors (top row) =====
    Sec[" Barangay Secretary / Officer<br/>admin · officer · brgy_sec"]
    Tanod[" Barangay Tanod"]
    Res[" Resident / Public · no login"]

    subgraph SYS[PROTECT System]
      direction TB

      UC_Login(["Authenticate / Login"])

      subgraph G1[Resident & Identity]
        direction LR
        UC_Res(["Manage Resident &<br/>Household Profiles"])
        UC_GIS(["Pin Households<br/>on GIS Map"])
        UC_QR(["Verify Resident<br/>via QR"])
        UC_Doc(["Issue Barangay<br/>Document"])
      end

      subgraph G3[Peace & Order / Safety]
        direction LR
        UC_Log(["Log Crime /<br/>Incident"])
        UC_Stat(["Update Incident<br/>Status"])
        UC_Hot(["View Crime<br/>Hotspot Map"])
        UC_Dis(["Mark Disaster<br/>Risk Zones"])
      end

      subgraph G2[Community Services]
        direction LR
        UC_Ben(["Manage Beneficiaries<br/>& Programs"])
        UC_Aid(["Process Assistance<br/>Release"])
        UC_Ann(["Post Announcements"])
      end

      subgraph G4[Analytics & Reports]
        direction LR
        UC_Ana(["View Analytics<br/>Dashboards"])
        UC_Pred(["View Predictive<br/>Growth"])
        UC_Needs(["View Needs<br/>Assessment"])
        UC_Rep(["Generate DILG<br/>Reports"])
      end

      subgraph G5[Public Portal]
        direction LR
        UC_Submit(["Submit Community<br/>Needs"])
        UC_PubAnn(["View Public<br/>Announcements"])
      end
    end

    %% ===== Secretary / Officer — full access (whole groups) =====
    Sec === UC_Login
    Sec === G1
    Sec === G2
    Sec === G3
    Sec === G4

    %% ===== Tanod — peace & order only =====
    Tanod --- UC_Login
    Tanod --- UC_Log
    Tanod --- UC_Stat
    Tanod --- UC_Hot

    %% ===== Resident / Public — no login =====
    Res --- UC_Submit
    Res --- UC_PubAnn

    %% ===== Styling =====
    classDef actor fill:#1A3A5C,stroke:#10243a,color:#fff,font-weight:bold;
    classDef resident fill:#0D9E8C,stroke:#0a7a6a,color:#fff;
    classDef community fill:#FCEEDB,stroke:#C9A84C,color:#5A4A1A;
    classDef safety fill:#FDEAEA,stroke:#D88888,color:#7A2A2A;
    classDef analytics fill:#EAF0FB,stroke:#7FA3DB,color:#1A3A5C;
    classDef auth fill:#EDE9DF,stroke:#9A9488,color:#3A3A32;
    classDef public fill:#F0FBF9,stroke:#0D9E8C,color:#0a5a50;

    class Sec,Tanod,Res actor;
    class UC_Login auth;
    class UC_Res,UC_GIS,UC_QR,UC_Doc resident;
    class UC_Ben,UC_Aid,UC_Ann community;
    class UC_Log,UC_Stat,UC_Hot,UC_Dis safety;
    class UC_Ana,UC_Pred,UC_Needs,UC_Rep analytics;
    class UC_Submit,UC_PubAnn public;
