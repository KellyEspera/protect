flowchart LR
    %% ===== Actors =====
    Sec[" Barangay Secretary / Officer<br/>admin · officer · brgy_sec"]
    Tanod[" Barangay Tanod"]
    DILG[" DILG Representative<br/>read-only"]
    Res[" Resident / Public<br/>no login"]

    subgraph SYS[PROTECT System]
      direction TB

      UC_Login(["Authenticate / Login"])

      subgraph G1[Resident & Identity]
        direction TB
        UC_Res(["Manage Resident &<br/>Household Profiles"])
        UC_GIS(["Pin Households on GIS Map"])
        UC_QR(["Verify Resident via QR"])
        UC_Doc(["Issue Barangay Document"])
      end

      subgraph G2[Community Services]
        direction TB
        UC_Ben(["Manage Beneficiaries &<br/>Programs"])
        UC_Aid(["Process Assistance Release"])
        UC_Ann(["Post Announcements"])
      end

      subgraph G3[Peace & Order / Safety]
        direction TB
        UC_Log(["Log Crime / Incident"])
        UC_Stat(["Update Incident Status"])
        UC_Hot(["View Crime Hotspot Map"])
        UC_Dis(["Mark Disaster Risk Zones"])
      end

      subgraph G4[Analytics & Reports]
        direction TB
        UC_Ana(["View Analytics Dashboards"])
        UC_Pred(["View Predictive Growth"])
        UC_Needs(["View Needs Assessment"])
        UC_Rep(["Generate DILG Reports"])
      end

      subgraph G5[Public Portal]
        direction TB
        UC_Submit(["Submit Community Needs"])
        UC_PubAnn(["View Public Announcements"])
      end
    end

    %% ===== Secretary / Officer — full access =====
    Sec --- UC_Login
    Sec --- UC_Res
    Sec --- UC_GIS
    Sec --- UC_QR
    Sec --- UC_Doc
    Sec --- UC_Ben
    Sec --- UC_Aid
    Sec --- UC_Ann
    Sec --- UC_Log
    Sec --- UC_Stat
    Sec --- UC_Hot
    Sec --- UC_Dis
    Sec --- UC_Ana
    Sec --- UC_Pred
    Sec --- UC_Needs
    Sec --- UC_Rep

    %% ===== Tanod — peace & order only =====
    Tanod --- UC_Login
    Tanod --- UC_Log
    Tanod --- UC_Stat
    Tanod --- UC_Hot

    %% ===== DILG Rep — read-only review =====
    DILG --- UC_Login
    DILG --- UC_Rep
    DILG --- UC_Needs

    %% ===== Resident / Public — no login =====
    Res --- UC_Submit
    Res --- UC_PubAnn

